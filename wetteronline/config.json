{
  "name": "WetterOnline Scraper",
  "version": "1.11.0",
  "slug": "wetteronline",
  "description": "Scrapes hourly temperature and cloud/sun data from WetterOnline and publishes via MQTT with auto-discovery.",
  "startup": "services",
  "boot": "auto",
  "type": "addon",
  "image": "local/wetteronline",
  "arch": ["amd64", "aarch64"],
  "options": {
    "location": "grafing",
    "interval": 30,
    "mqtt_host": "core-mosquitto",
    "mqtt_port": 1883
  },
  "schema": {
    "location": "str",
    "interval": "int",
    "mqtt_host": "str",
    "mqtt_port": "int"
  },
  "build_from": {
    "aarch64": "ghcr.io/hassio-addons/base-python:17.0.0",
    "amd64": "ghcr.io/hassio-addons/base-python:17.0.0"
  }
}
